# Server
PORT=3001
NODE_ENV=development
# For production on cPanel, set NODE_ENV=production

# Database
# Local dev (matches docker-compose.yml):
DB_HOST=localhost
DB_PORT=3306
DB_USER=orchestra
DB_PASSWORD=orchestra_pass
DB_NAME=orchestra_attendance
# For cPanel: use the DB credentials from cPanel → MySQL Databases

# JWT — change this to a long random string in production!
JWT_SECRET=your-secret-key-change-this-in-production
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# Email — two providers supported:
#
# Option 1: SMTP (set SMTP_ENABLED=true)
SMTP_ENABLED=false
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
#
# Option 2: Resend API (used when SMTP_ENABLED is not true)
# Get your API key from https://resend.com/api-keys
# Leave RESEND_API_KEY blank to use dev mode (codes shown on screen).
RESEND_API_KEY=re_your_api_key_here
#
# Sender address (used by both providers)
# Use onboarding@resend.dev for testing with Resend, or your verified domain for production
EMAIL_FROM=Orchestra <onboarding@resend.dev>

# Frontend URL (for CORS, and Mollie redirect back)
# Local dev:
FRONTEND_URL=http://localhost:5173
# Production: set to your actual domain, e.g.:
# FRONTEND_URL=https://attendance.yourdomain.com

# Backend URL (used as the public webhook target for Mollie)
# Must be reachable from the public internet in production.
BACKEND_URL=http://localhost:3001

# Mollie (Bancontact + Wero payments)
# Get your API key from https://my.mollie.com/dashboard/developers/api-keys
# Use test_... for development, live_... for production.
MOLLIE_API_KEY=test_your_mollie_key_here

# Master switch for the online-payment feature.
# When false (or missing) the "Pay now" button is hidden and the
# backend returns 403 on payment endpoints. Default: false.
PAYMENTS_ENABLED=false
