# Server
PORT=3001
NODE_ENV=development
# For production on cPanel, set NODE_ENV=production

# Database
# Local dev (matches docker-compose.yml):
DB_HOST=localhost
DB_PORT=3306
DB_USER=orchestra
DB_PASSWORD=orchestra_pass
DB_NAME=orchestra_attendance
# For cPanel: use the DB credentials from cPanel → MySQL Databases

# JWT — change this to a long random string in production!
JWT_SECRET=your-secret-key-change-this-in-production
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# Email (Resend — for login codes)
# Get your API key from https://resend.com/api-keys
# Leave RESEND_API_KEY blank to use dev mode (codes shown on screen).
RESEND_API_KEY=re_your_api_key_here
# Use onboarding@resend.dev for testing, or your verified domain for production
EMAIL_FROM=Orchestra <onboarding@resend.dev>

# Frontend URL (for CORS)
# Local dev:
FRONTEND_URL=http://localhost:5173
# Production: set to your actual domain, e.g.:
# FRONTEND_URL=https://attendance.yourdomain.com
