# ===========================================
# Orchestra Attendance — Production Config
# Copy this to .env and fill in your values
# ===========================================

# --- App ---
PORT=3001
NODE_ENV=development

# --- Database (must match docker-compose) ---
DB_ROOT_PASSWORD=CHANGE_ME_strong_root_password
DB_HOST=mysql
DB_PORT=3306
DB_USER=orchestra
DB_PASSWORD=CHANGE_ME_strong_db_password
DB_NAME=orchestra_attendance

# --- JWT ---
# Generate with: openssl rand -base64 48
JWT_SECRET=CHANGE_ME_random_secret
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# --- Email — two providers supported ---
# Option 1: SMTP (set SMTP_ENABLED=true)
SMTP_ENABLED=false
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password

# Option 2: Resend API (used when SMTP_ENABLED is not true)
RESEND_API_KEY=re_your_api_key_here

# Sender address (used by both providers)
EMAIL_FROM=Orchestra <noreply@yourdomain.com>

# --- Frontend URL ---
# Used for CORS — include the /orchestra subpath
FRONTEND_URL=https://yourdomain.com/orchestra

# --- Backend public URL (Mollie webhook target) ---
BACKEND_URL=https://yourdomain.com

# --- Online payments (Mollie: Bancontact + Wero) ---
# Off by default. Set PAYMENTS_ENABLED=true and provide MOLLIE_API_KEY to enable.
PAYMENTS_ENABLED=false
MOLLIE_API_KEY=test_your_mollie_key_here